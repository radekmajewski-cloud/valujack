<script>
(function(){
  var IMAGES = [
    'data:image/jpeg;base64,',
    'data:image/jpeg;base64,',
    'data:image/jpeg;base64,',
    'data:image/jpeg;base64,',
    'data:image/jpeg;base64,'
  ];
  var TEXTS  = ['Scanning the market for value...', 'Searching your daily opportunities...', 'Analysing your investment edge...', 'Preparing your market insights...', 'Finding your strongest cards today...'];

  // Pick index based on day of year — changes daily
  function dailyIndex() {
    return Math.floor(Math.random() * IMAGES.length);
  }

  window.showLoader = function(onDone) {
    var idx = dailyIndex();
    var loader = document.getElementById('loader');
    var img    = document.getElementById('loaderImg');
    var txt    = document.getElementById('loaderText');

    img.style.backgroundImage = 'url(' + IMAGES[idx] + ')';
    txt.textContent = TEXTS[idx];
    // Reset text animation
    txt.style.animation = 'none';
    txt.offsetHeight; // reflow
    txt.style.animation = 'loaderTextIn 1s ease 0.5s forwards';

    loader.style.display  = 'block';
    loader.style.opacity  = '1';
    loader.style.animation = 'none';

    // After 4 seconds fade out and reveal table
    setTimeout(function(){
      loader.style.animation = 'loaderFadeOut 0.7s ease forwards';
      setTimeout(function(){
        loader.style.display = 'none';
        document.getElementById('root').style.visibility = 'visible';
        if(onDone) onDone();
      }, 700);
    }, 4000);
  };
})();
</script>


